{
  "build": {
    "env": {
      "HUGO_VERSION": "0.145.0"
    }
  },
  "buildCommand": "sh ./scripts/build_website.sh",
  "redirects": [
    { "source": "/docs", "destination": "/", "permanent": false },
    { "source": "/docs/:path*", "destination": "/", "permanent": false },
    { "source": "/youtube", "destination": "https://youtube.com/c/OONIorg" },
    {
      "source": "/imv2020-survey",
      "destination": "https://ooni.typeform.com/to/cPVT4ILB"
    },
    {
      "source": "/en/messages/:splat*",
      "has": [{ "type": "host", "value": "msg.ooni.io" }],
      "destination": "https://ooni.org/msg/:splat*",
      "permanent": true
    },
    {
      "source": "/fr/messages/:splat*",
      "has": [{ "type": "host", "value": "msg.ooni.io" }],
      "destination": "https://ooni.org/fr/msg/:splat*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "msg.ooni.io" }],
      "destination": "https://ooni.org/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "labs.ooni.io"
        }
      ],
      "destination": "https://ooni.org/retired/labs",
      "permanent": true
    }
  ]
}
